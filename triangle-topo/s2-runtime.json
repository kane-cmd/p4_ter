{
  "target": "bmv2",
  "p4info": "build/basic.p4.p4info.txtpb",
  "bmv2_json": "build/basic.json",
  "table_entries": [
    {
      "table": "MyIngress.ipv6_lpm",
      "default_action": true,
      "action_name": "MyIngress.drop",
      "action_params": {}
    },
    {
      "table": "MyIngress.ipv6_lpm",
      "match": {
        "hdr.ipv6.dstAddr": [
          "2001:1::1",
          128
        ]
      },
      "action_name": "MyIngress.ipv6_forward",
      "action_params": {
        "dstAddr": "08:00:00:00:01:00",
        "port": 2
      }
    },
    {
      "table": "MyIngress.ipv6_lpm",
      "match": {
        "hdr.ipv6.dstAddr": [
          "2001:2::2",
          128
        ]
      },
      "action_name": "MyIngress.ipv6_forward",
      "action_params": {
        "dstAddr": "08:00:00:00:02:22",
        "port": 1
      }
    },
    {
      "table": "MyIngress.ipv6_lpm",
      "match": {
        "hdr.ipv6.dstAddr": [
          "2001:3::3",
          128
        ]
      },
      "action_name": "MyIngress.ipv6_forward",
      "action_params": {
        "dstAddr": "08:00:00:00:03:00",
        "port": 3
      }
    }
  ]
}
